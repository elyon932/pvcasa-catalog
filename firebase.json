{
  "hosting": [
    {
      "target": "client",
      "public": "dist/client",
      "cleanUrls": true,
      "trailingSlash": false,
      "ignore": ["firebase.json", "**/.*"],
      "headers": [
        {
          "source": "**/*.@(html|css|js)",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "**/*.@(png|jpg|jpeg|svg|ico|webp)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
        }
      ]
    },
    {
      "target": "admin",
      "public": "dist/admin",
      "cleanUrls": true,
      "trailingSlash": false,
      "ignore": ["firebase.json", "**/.*"],
      "redirects": [{ "source": "/", "destination": "/auth", "type": 302 }],
      "headers": [
        {
          "source": "**/*.@(html|css|js)",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "**/*.@(png|jpg|jpeg|svg|ico|webp)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
        }
      ]
    }
  ]
}
