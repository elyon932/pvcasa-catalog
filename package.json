  },
  "dependencies": {
    "firebase": "12.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
